@model AssessmentViewModel

<h2 class="text-center">Mental Health Assessment</h2>
<p class="text-center text-muted">
    Please answer honestly. This helps us understand your mental state.
</p>

<div class="progress mb-4">
    <div id="progressBar" class="progress-bar bg-dark" style="width: 0%"></div>
</div>

<form asp-action="Submit" method="post" id="assessmentForm">

    @for (int i = 0; i < Model.Questions.Count; i++)
    {
        <div class="question-step" style="display:@(i == 0 ? "block" : "none")">

            <h4>Question @(i + 1) of @Model.Questions.Count</h4>

            <div class="card p-4 mt-3">
                <p>@Model.Questions[i].QuestionText</p>

                <div class="form-check">
                    <input type="radio" name="Answers[@Model.Questions[i].QuestionId]" value="1" required /> Not at all
                </div>
                <div class="form-check">
                    <input type="radio" name="Answers[@Model.Questions[i].QuestionId]" value="2" /> Several days
                </div>
                <div class="form-check">
                    <input type="radio" name="Answers[@Model.Questions[i].QuestionId]" value="3" /> More than half the days
                </div>
                <div class="form-check">
                    <input type="radio" name="Answers[@Model.Questions[i].QuestionId]" value="4" /> Nearly every day
                </div>
            </div>

            <div class="mt-3">
                @if (i < Model.Questions.Count - 1)
                {
                    <button type="button" class="btn btn-dark nextBtn">Next</button>
                }
                else
                {
                    <button type="submit" class="btn btn-success">Submit</button>
                }
            </div>

        </div>
    }
</form>

<script>
    let current = 0;
    const steps = document.querySelectorAll(".question-step");
    const progress = document.getElementById("progressBar");

    function updateProgress() {
        let percent = ((current + 1) / steps.length) * 100;
        progress.style.width = percent + "%";
    }

    updateProgress();

    document.querySelectorAll(".nextBtn").forEach(btn => {
        btn.addEventListener("click", () => {

            
            const selected = steps[current].querySelector("input:checked");
            if (!selected) {
                alert("Please select an answer");
                return;
            }

            steps[current].style.display = "none";
            current++;
            steps[current].style.display = "block";

            updateProgress();
        });
    });
</script>