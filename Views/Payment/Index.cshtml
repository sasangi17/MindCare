@{
}

<script src="https://www.paypal.com/sdk/js?client-id=@(ViewBag.PaypalClientId)&currency=USD"></script>

<div class="container mt-5">
    <div class="row g-4">

      
        <div class="col-md-7">

            <div class="card p-4 shadow-sm rounded-4">

                <h5 class="mb-4">Choose your payment method</h5>

            
                <div class="payment-box active">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <input type="radio" checked />
                            <strong class="ms-2">PayPal</strong>
                            <p class="text-muted small mb-0">
                                Safe payment online.
                            </p>
                        </div>

                        <img src="https://www.paypalobjects.com/webstatic/icon/pp258.png" width="70" />
                    </div>
                </div>

             
                <div class="mt-4" id="paypal-button-container"></div>

             
                <div id="notification-container" class="mt-3"></div>

            </div>

        </div>

 
        <div class="col-md-5">

            <div class="card p-4 shadow-sm rounded-4">

                <h5>Summary</h5>

                <p><b>Doctor:</b> @ViewBag.DoctorName</p>
                <p><b>Date:</b> @ViewBag.Date</p>
                <p><b>Time:</b> @ViewBag.Time</p>

                <hr />

                <div class="d-flex justify-content-between">
                    <span>Consultation Fee</span>
                    <span>Rs. @ViewBag.Fee</span>
                </div>

                <hr />

                <h4 class="text-success text-end">
                    Rs. @ViewBag.Fee
                </h4>

              
                <input type="hidden" id="totalAmount" value="@ViewBag.Fee" />

            </div>

        </div>

    </div>
</div>

<style>

    body {
        background: #f6f8fb;
    }

 
    .payment-box {
        border: 1px solid #e0e0e0;
        padding: 15px;
        border-radius: 12px;
        transition: 0.3s;
    }

        .payment-box.active {
            border: 2px solid #0070ba;
            background: #f0f8ff;
        }


    .card {
        border: none;
    }

    #paypal-button-container {
        margin-top: 10px;
    }

</style>

<script>
    paypal.Buttons({

        async createOrder() {
            const response = await fetch("@Url.ActionLink("CreateOrder", "Payment")", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                },
                body: JSON.stringify({
                    amount: document.getElementById("totalAmount").value
                })
            });

            const order = await response.json();
            return order.id;
        },

        onApprove: function (data, actions) {
            return actions.order.capture().then(function (details) {

                document.getElementById("notification-container").innerHTML = `
                <div class="alert alert-success">Payment Successful!</div>
                `;

                window.location.href = "/Consultation/SaveAfterPayment";
            });
        },

        onCancel(data) {
            document.getElementById("notification-container").innerHTML = `
            <div class="alert alert-danger">Payment Canceled!</div>
            `;
        },

        onError(err) {
            document.getElementById("notification-container").innerHTML = `
            <div class="alert alert-danger">An error occurred!</div>
            `;
        }

    }).render('#paypal-button-container');
</script>