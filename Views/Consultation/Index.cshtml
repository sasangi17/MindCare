@model List<MindCare_Pro.Models.Doctor>

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h3 class="fw-bold mb-1">
                Find a Doctor
            </h3>

            <span class="text-muted">
                @Model.Count doctors available
            </span>
        </div>

        <a href="/Consultation/MyAppointments"
           class="btn btn-dark px-4">

            My Appointments

        </a>

    </div>

    <div class="row g-4">

        @foreach (var d in Model)
        {
            <div class="col-md-4">

                <div class="card doctor-card h-100">

                    <div class="d-flex align-items-center mb-3">
                        <div class="avatar">
                            @d.Name.Substring(0, 1)
                        </div>

                        <div class="ms-3">
                            <h6 class="mb-0">@d.Name</h6>
                            <small class="text-muted">@d.Specialization</small>
                        </div>
                    </div>

                    <p class="text-muted small mb-3">
                        @d.Description
                    </p>

                    <div class="fee-box">
                        <span>Consultation Fee</span>
                        <strong>Rs. @d.Fee.ToString("N0")</strong>
                    </div>

                    <a href="/Consultation/Book/@d.DoctorId"
                       class="btn btn-main mt-3 w-100">
                        Book Appointment
                    </a>

                </div>

            </div>
        }

    </div>
</div>

<style>
    .doctor-card {
        background: white;
        padding: 20px;
        border-radius: 16px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.05);
        transition: 0.3s;
    }

        .doctor-card:hover {
            transform: translateY(-5px);
        }

    .avatar {
        width: 45px;
        height: 45px;
        background: #000;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
    }

    .fee-box {
        display: flex;
        justify-content: space-between;
        background: #f5f5f5;
        padding: 10px;
        border-radius: 10px;
    }

    .btn-main {
        background: #000;
        color: white;
        border-radius: 10px;
    }

.btn-main:hover{
    color:white;
}
</style>