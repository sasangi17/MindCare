@model MindCare_Pro.Models.BookingViewModel

<div class="container mt-5">

    <div class="row g-4">

        
        <div class="col-md-7">

            <div class="card p-4 shadow-sm rounded-4">

              
                <div class="d-flex align-items-center mb-3">
                    <div class="avatar">
                        @Model.DoctorName.Substring(0, 1)
                    </div>

                    <div class="ms-3">
                        <h5 class="mb-0">@Model.DoctorName</h5>
                        <small class="text-muted">Specialist</small>
                    </div>
                </div>

               
                <p class="text-muted mb-2">
                    Professional consultation available online
                </p>

                <div class="badge bg-light text-dark p-2 rounded-pill mb-2">
                    Online Consultation
                </div>

                
                <div class="mt-3">
                    <strong>Available Time</strong>
                    <p class="text-muted mb-0">Morning & Evening Sessions</p>
                </div>

                <div class="fee-box mt-4">
                    <span>Consultation Fee</span>
                    <strong>Rs. @Model.Fee.ToString("N0")</strong>
                </div>

            </div>

        </div>

        <div class="col-md-5">

            <div class="card p-4 shadow-sm rounded-4">

                <form method="post">

                    <input type="hidden" asp-for="DoctorId" />
                    <input type="hidden" asp-for="DoctorName" />
                    <input type="hidden" asp-for="Fee" />
                    <input type="hidden" asp-for="SelectedDate" id="date" />
                    <input type="hidden" asp-for="SelectedTime" id="time" />

                  
                    <h6 class="fw-bold mb-3">Select Date</h6>

                    <input type="date"
                           class="form-control mb-4"
                           onchange="document.getElementById('date').value=this.value" />

                 
                    <h6 class="fw-bold mb-2">Visit Hours</h6>

                    <div class="time-grid mb-4">
                        @foreach (var t in Model.TimeSlots)
                        {
                            <button type="button"
                                    class="time-slot"
                                    onclick="setTime('@t', this)">
                                @t
                            </button>
                        }
                    </div>

                   
                    <button class="btn btn-main w-100">
                        Book an Appointment →
                    </button>

                </form>

            </div>

        </div>

    </div>

</div>

<style>

    body {
        background: #f5f7fb;
    }

    
    .avatar {
        width: 50px;
        height: 50px;
        background: #000;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 18px;
    }

   
    .fee-box {
        display: flex;
        justify-content: space-between;
        background: #f1f3f6;
        padding: 12px;
        border-radius: 12px;
    }

   
    .time-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 10px;
    }

 
    .time-slot {
        padding: 10px;
        border-radius: 10px;
        border: 1px solid #ddd;
        background: white;
        cursor: pointer;
        transition: 0.2s;
    }

        .time-slot:hover {
            background: #000;
            color: white;
        }

        .time-slot.active {
            background: #000;
            color: white;
        }

    .btn-main {
        background: #000;
        color: white;
        border-radius: 12px;
        padding: 10px;
        font-weight: 600;
    }
    .btn-main:hover{
        color:white;
    }

</style>

<script>
    function setTime(val, btn){
        document.getElementById('time').value = val;

        document.querySelectorAll('.time-slot')
            .forEach(b => b.classList.remove('active'));

        btn.classList.add('active');
    }
</script>