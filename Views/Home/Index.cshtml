@{
    ViewData["Title"] = "Welcome";
    Layout = "_Layout";

    
    ViewData["HideFooter"] = true;
}

<style>
    .top-right-btn {
        position: absolute;
        top: 20px;
        right: 20px;
        z-index: 10;
    }

    .main-section {
        min-height: calc(100vh - 70px);
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #f8f9fa;
        flex-direction: column;
        padding-top: 20px;
    }

    .content-box {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 60px;
        background: white;
        padding: 50px;
        border-radius: 20px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
        margin-bottom: 60px;
        max-width: 1100px;
        width: 100%;
    }

    .content-text {
        flex: 1;
    }

    .content-image {
        flex: 1;
        display: flex;
        justify-content: center;
    }

        .content-image img {
            width: 100%;
            max-width: 450px;
            height: 450px;
            object-fit: cover;
            border-radius: 20px;
        }

    .feature-cards {
        display: flex;
        gap: 30px;
        justify-content: center;
        flex-wrap: wrap;
        max-width: 1100px;
    }

    .feature-card {
        width: 300px;
        border: none;
        border-radius: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        transition: 0.3s ease;
    }

        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
        }

    .cta-section {
        width: 100%;
        display: flex;
        justify-content: center;
        margin-top: 40px;
    }

    .cta-box {
        background: linear-gradient(135deg, #4e73df, #1cc88a);
        color: white;
        padding: 60px;
        border-radius: 25px;
        width: 80%;
        max-width: 900px;
        text-align: center;
        box-shadow: 0 8px 30px rgba(0,0,0,0.15);
    }
</style>


@if (User.Identity.IsAuthenticated)
{
    <a asp-controller="Dashboard" asp-action="Index"
       class="btn btn-success top-right-btn">
        Go to Dashboard
    </a>
}
else
{
    <a asp-area="Identity"
       asp-page="/Account/Login"
       class="btn btn-primary top-right-btn">
        Get Started
    </a>
}

<div class="main-section">

   
    <div class="content-box">

        <div class="content-text">
            <h1 class="display-4 fw-bold">Welcome to MindCare</h1>
            <h3 class="mt-3">Your Journey to Better Mental Health Starts Here</h3>

            <p class="lead mt-4">
                Take control of your mental wellness with personalized assessments,
                professional support, and evidence-based tools designed to help you thrive.
            </p>
        </div>

        <div class="content-image">
            <img src="~/images/cover.jpeg" alt="MindCare Image" />
        </div>

    </div>

    
    <div class="feature-cards">

        <div class="card feature-card p-4 text-center">
            <div class="card-body">
                <h4 class="fw-bold">Mental Health Assessment</h4>
                <p class="mt-3">
                    Understand your emotional well-being with guided assessments.
                </p>
            </div>
        </div>

        <div class="card feature-card p-4 text-center">
            <div class="card-body">
                <h4 class="fw-bold">Wellness Reminders</h4>
                <p class="mt-3">
                    Stay consistent with self-care and healthy habits.
                </p>
            </div>
        </div>

        <div class="card feature-card p-4 text-center">
            <div class="card-body">
                <h4 class="fw-bold">Progress Tracking</h4>
                <p class="mt-3">
                    Visualize your journey and monitor improvements over time.
                </p>
            </div>
        </div>

    </div>

    
    <div class="cta-section">
        <div class="cta-box">
            <h2 class="fw-bold">Ready to Prioritize Your Mental Health?</h2>

            <p class="lead mt-3">
                Take the first step toward a healthier and more balanced life.
            </p>

            @if (!User.Identity.IsAuthenticated)
            {
                <a asp-area="Identity"
                   asp-page="/Account/Register"
                   class="btn btn-light btn-lg mt-3">
					Register Now
                </a>
            }
            else
            {
                <a asp-controller="Assessment"
                   asp-action="Index"
                   class="btn btn-light btn-lg mt-3">
                    Start Assessment
                </a>
            }
        </div>
    </div>

</div>