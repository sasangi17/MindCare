@model MindCare_Pro.Models.Doctor

<div class="card border-0 shadow-sm rounded-4 p-4">

    <h3 class="fw-bold mb-4">
        Edit Doctor
    </h3>

    <form method="post">

        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="DoctorId" />

        <div class="mb-3">

            <label class="form-label">
                Doctor Name
            </label>

            <input asp-for="Name"
                   class="form-control" />

        </div>

        <div class="mb-3">

            <label class="form-label">
                Specialization
            </label>

            <input asp-for="Specialization"
                   class="form-control" />

        </div>

        <div class="mb-3">

            <label class="form-label">
                Description
            </label>

            <textarea asp-for="Description"
                      class="form-control"></textarea>

        </div>

        <div class="mb-4">

            <label class="form-label">
                Consultation Fee
            </label>

            <input asp-for="Fee"
                   class="form-control" />

        </div>

        <button class="btn btn-dark">

            Update Doctor

        </button>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}