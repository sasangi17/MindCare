@model MindCare_Pro.Models.AdminUserMentalHealthViewModel

<div class="card shadow-sm border-0 rounded-4 p-4">

    <h2 class="fw-bold mb-4">
        Mental Health Report
    </h2>

    <div class="mb-4">

        <h4>
            @Model.FirstName @Model.LastName
        </h4>

        <p class="text-muted">
            @Model.UserName
        </p>

    </div>

    <div class="row">

        <div class="col-md-3 mb-3">
            <div class="card p-3 border-0 shadow-sm">
                <h6>Total Score</h6>
                <h2>@Model.TotalScore</h2>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card p-3 border-0 shadow-sm">
                <h6>Depression</h6>
                <h2>@Model.DepressionScore</h2>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card p-3 border-0 shadow-sm">
                <h6>Anxiety</h6>
                <h2>@Model.AnxietyScore</h2>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card p-3 border-0 shadow-sm">
                <h6>Stress</h6>
                <h2>@Model.StressScore</h2>
            </div>
        </div>

    </div>

    <div class="alert alert-warning mt-3">

        <strong>
            Current Condition:
        </strong>

        @Model.CurrentCondition

    </div>

    <hr />

    <h4 class="fw-bold mb-3">
        Assessment History
    </h4>

    <table class="table">

        <thead>
            <tr>
                <th>Date</th>
                <th>Total</th>
                <th>Depression</th>
                <th>Anxiety</th>
                <th>Stress</th>
                <th>Condition</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model.History)
            {
                <tr>

                    <td>
                        @item.AssessmentDate.ToShortDateString()
                    </td>

                    <td>@item.TotalScore</td>

                    <td>@item.DepressionScore</td>

                    <td>@item.AnxietyScore</td>

                    <td>@item.StressScore</td>

                    <td>

                        @if (item.Condition == "Low")
                        {
                            <span class="badge bg-success">
                                Low
                            </span>
                        }
                        else if (item.Condition == "Moderate")
                        {
                            <span class="badge bg-warning text-dark">
                                Moderate
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger">
                                Critical
                            </span>
                        }

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>